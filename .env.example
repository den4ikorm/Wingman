# ── ОБЯЗАТЕЛЬНЫЕ ──────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_here
ADMIN_ID=your_telegram_id_here

# ── GEMINI API (хотя бы 1 ключ) ───────────────────────
GEMINI_KEY_1=your_gemini_key_here
GEMINI_KEY_2=
GEMINI_KEY_3=

# ── ОПЦИОНАЛЬНО: GROQ (fallback для текста) ────────────
GROQ_API_KEY=

# ── FSM ХРАНИЛИЩЕ (Railway Redis addon) ───────────────
# БЕЗ этого анкета сбрасывается при каждом рестарте!
REDIS_URL=redis://default:password@host:6379

# ── БАЗА ДАННЫХ (Railway Volume) ──────────────────────
# Если не задан — автоматически ./data/wingman.db
DB_PATH=/mnt/data/wingman.db

# ── WEBAPP (после деплоя статики на Railway) ──────────
WEBAPP_URL=https://your-webapp.up.railway.app

# ── МОДЕЛЬ GEMINI ─────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash-lite
