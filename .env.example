# ============================================================
# Wingman v3 — переменные окружения
# Скопируй в Railway → Variables
# ============================================================

# ── TELEGRAM ────────────────────────────────────────────────
TELEGRAM_TOKEN=8648523186:ААА...

# Твой личный Telegram user_id (для получения фидбека от юзеров)
# Узнать: написать @userinfobot
ADMIN_ID=123456789

# ── GEMINI API КЛЮЧИ (ротация) ──────────────────────────────
# Минимум 1 ключ, максимум 5
# Получить: https://aistudio.google.com/app/apikey
GEMINI_KEY_1=AIzaSy...первый_ключ
GEMINI_KEY_2=AIzaSy...второй_ключ
GEMINI_KEY_3=AIzaSy...третий_ключ
GEMINI_KEY_4=AIzaSy...четвёртый_ключ
# GEMINI_KEY_5=AIzaSy...пятый_ключ  # опционально

# ── TMDB (для будущих рекомендаций фильмов) ─────────────────
# Получить: https://www.themoviedb.org/settings/api
# Пока не используется в коде, зарезервировано
TMDB_API_KEY=твой_tmdb_ключ

# ── SPOONACULAR (рецепты) ────────────────────────────────────
# Получить: https://spoonacular.com/food-api
SPOON_KEY=00fab8b23e0c4a4488eab7218a0ffc0b

# ── EDAMAM (нутриенты) ───────────────────────────────────────
E_NUTR_ID=4c8565b8
E_NUTR_KEY=8bfb18d94ef5f5b8805be79e934c07be
E_REC_ID=2a527e5e
E_REC_KEY=0f25d6cee32f9014d6ef84e399d8fb23

# ── СИСТЕМА ──────────────────────────────────────────────────
BASE_DIR=./data

# Путь к SQLite базе (Railway Volume или ./data для теста)
# Для Railway Volume: примонтируй Volume на /app/data
DB_PATH=./data/wingman.db
